generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

// ─── Enumerations ─────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── Models ───────────────────────────────────────────────────────────────────

// Synced from Clerk via webhook. Clerk user ID is the primary key.
model User {
  id          String   @id           // Clerk userId, e.g. "user_abc123"
  email       String   @unique
  firstName   String?
  lastName    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships UserAppMembership[]
  auditLogs   AuditLog[]
}

// One row per Famalii app. Add new apps by inserting a row here.
model App {
  id          String   @id @default(cuid())
  slug        String   @unique       // e.g. "famalii-invest"
  name        String                 // e.g. "Famalii Invest"
  description String
  iconUrl     String?
  launchUrl   String                 // e.g. "https://invest.famalii.com"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  memberships UserAppMembership[]
  auditLogs   AuditLog[]
}

// Junction table: which users have joined which apps, and at what role.
model UserAppMembership {
  id        String   @id @default(cuid())
  userId    String
  appId     String
  role      Role     @default(MEMBER)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  app  App  @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([userId, appId])
  @@index([userId])
  @@index([appId])
}

// Append-only event log for auditing auth and membership actions.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  appSlug   String?
  action    String   // e.g. "app.joined", "user.created", "user.deleted"
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  app  App?  @relation(fields: [appSlug], references: [slug], onDelete: SetNull)

  @@index([userId])
  @@index([action])
}
